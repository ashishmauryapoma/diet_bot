# ── Telegram ──────────────────────────────────────────
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# ── Gemini AI ─────────────────────────────────────────
GEMINI_API_KEY=your_gemini_api_key_here

# ── Google Sheets ─────────────────────────────────────
GOOGLE_SHEETS_CREDENTIALS_JSON=path/to/service_account.json
SPREADSHEET_ID=your_google_spreadsheet_id_here

# ── Auth (auto-set on first login — DO NOT fill manually) ──
AUTHORIZED_USER_ID=
BOT_PASSWORD_HASH=

# ── Defaults (overridden by /profile settings stored in sheet) ──
DEFAULT_CALORIE_LIMIT=2000
DEFAULT_PROTEIN_GOAL=120
DEFAULT_CARBS_GOAL=250
DEFAULT_FAT_GOAL=65
DEFAULT_FIBER_GOAL=30
DEFAULT_WATER_GOAL_ML=2500
DEFAULT_TIMEZONE=Asia/Kolkata
